{
    "tasks": [
        {
            "type": "cmake",
            "label": "CMake: 构建 TOIRE Level Meter (Debug)",
            "command": "build",
            "targets": [
                "ALL_BUILD"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "detail": "CMake 构建 (MSVC Debug)"
        },
        {
            "type": "cmake",
            "label": "CMake: 清理重新构建",
            "command": "cleanRebuild",
            "targets": [
                "ALL_BUILD"
            ],
            "group": "build",
            "problemMatcher": [
                "$msCompile"
            ],
            "detail": "先清理再构建"
        },
        {
            "type": "shell",
            "label": "CMake: 命令行构建（备用）",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}\\build",
                "--config",
                "Debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": [
                "$msCompile"
            ],
            "detail": "绕过 CMake Tools，直接调 cmake.exe"
        }
    ],
    "version": "2.0.0"
}